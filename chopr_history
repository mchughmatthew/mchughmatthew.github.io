  .section-label {
    font-family: 'DM Mono', monospace; font-size: 0.7rem;
    color: var(--navy); letter-spacing: 0.2em; text-transform: uppercase;
    margin-bottom: 1.2rem; display: flex; align-items: center; gap: 0.8rem;
  }
  .section-label::after {
    content: ''; flex: 1; max-width: 60px; height: 1px; background: var(--navy); opacity: 0.4;
  }
  .timeline-heading {
    font-family: 'Cormorant Garamond', serif; font-weight: 400;
    font-size: 2.5rem; color: var(--navy); margin-bottom: 0.75rem; line-height: 1.15;
  }
  .timeline-intro {
    font-size: 1rem; color: var(--muted); font-weight: 300; line-height: 1.75;
    max-width: 600px; margin-bottom: 4rem;
  }

  /* vertical spine */
  .timeline-track {
    position: relative;
    padding: 0;
  }
  .timeline-track::before {
    content: ''; position: absolute;
    left: 50%; top: 0; bottom: 0;
    width: 1px;
    background: linear-gradient(to bottom, transparent, var(--timeline-line) 5%, var(--timeline-line) 95%, transparent);
    transform: translateX(-50%);
  }

  /* each event row */
  .tl-event {
    display: grid;
    grid-template-columns: 1fr 80px 1fr;
    gap: 0;
    margin-bottom: 0;
    position: relative;
    min-height: 100px;
    align-items: center;
    opacity: 0;
    transform: translateY(20px);
    transition: opacity 0.5s ease, transform 0.5s ease;
  }
  .tl-event.visible {
    opacity: 1;
    transform: translateY(0);
  }

  /* year node (center column) */
  .tl-node {
    display: flex; flex-direction: column; align-items: center;
    justify-content: center; position: relative; z-index: 2;
    padding: 1.5rem 0;
  }
  .tl-dot {
    width: 12px; height: 12px;
    border-radius: 50%;
    background: var(--navy);
    border: 2px solid var(--warm-white);
    box-shadow: 0 0 0 2px var(--navy);
    margin-bottom: 0.4rem;
    flex-shrink: 0;
  }
  .tl-event.milestone .tl-dot {
    width: 16px; height: 16px;
    background: var(--gold-accent);
    box-shadow: 0 0 0 2px var(--gold-accent), 0 0 12px rgba(230,217,138,0.4);
  }
  .tl-year {
    font-family: 'DM Mono', monospace; font-size: 0.72rem;
    color: var(--navy); letter-spacing: 0.1em; font-weight: 400;
    white-space: nowrap;
  }

  /* card (left or right column) */
  .tl-card {
    background: #fff;
    border: 1px solid var(--border);
    border-radius: 4px;
    padding: 1.4rem 1.6rem;
    position: relative;
    transition: box-shadow 0.2s, transform 0.2s;
    margin: 1rem 0;
  }
  .tl-card:hover {
    box-shadow: 0 6px 24px rgba(12,27,51,0.09);
    transform: translateY(-2px);
  }
  .tl-event.milestone .tl-card {
    border-top: 3px solid var(--gold-accent);
  }

  /* left-side card: right column empty */
  .tl-event.left .tl-card  { grid-column: 1; margin-right: 1.5rem; }
  .tl-event.left .tl-node  { grid-column: 2; }
  .tl-event.left .tl-empty { grid-column: 3; }

  /* right-side card: left column empty */
  .tl-event.right .tl-empty { grid-column: 1; }
  .tl-event.right .tl-node  { grid-column: 2; }
  .tl-event.right .tl-card  { grid-column: 3; margin-left: 1.5rem; }

  /* connector arrow nub */
  .tl-event.left .tl-card::after {
    content: ''; position: absolute;
    right: -7px; top: 50%; transform: translateY(-50%);
    border-top: 6px solid transparent;
    border-bottom: 6px solid transparent;
    border-left: 7px solid var(--border);
  }
  .tl-event.left .tl-card::before {
    content: ''; position: absolute;
    right: -6px; top: 50%; transform: translateY(-50%);
    border-top: 5px solid transparent;
    border-bottom: 5px solid transparent;
    border-left: 6px solid #fff;
    z-index: 1;
  }
  .tl-event.right .tl-card::after {
    content: ''; position: absolute;
    left: -7px; top: 50%; transform: translateY(-50%);
    border-top: 6px solid transparent;
    border-bottom: 6px solid transparent;
    border-right: 7px solid var(--border);
  }
  .tl-event.right .tl-card::before {
    content: ''; position: absolute;
    left: -6px; top: 50%; transform: translateY(-50%);
    border-top: 5px solid transparent;
    border-bottom: 5px solid transparent;
    border-right: 6px solid #fff;
    z-index: 1;
  }
  .tl-event.milestone.right .tl-card::before { border-right-color: #fff; }

  .tl-card-category {
    font-family: 'DM Mono', monospace; font-size: 0.65rem;
