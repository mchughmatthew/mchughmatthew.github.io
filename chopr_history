  .tl-ps-item { background: #fff; padding: 1rem 1.2rem; border-radius: 3px; border-left: 3px solid var(--gold-accent); }
  .tl-ps-n {
    font-family: 'Cormorant Garamond', serif; font-size: 1.8rem; font-weight: 300;
