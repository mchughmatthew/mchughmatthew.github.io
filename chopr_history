    .tl-event.right .tl-card::after,
    .tl-event.right .tl-card::before { display: none; }

    .tl-quote-block { padding: 2rem 1.5rem; }
    .tl-quote-block blockquote { font-size: 1.2rem; }
    .tl-present { grid-template-columns: 1fr; padding: 1.8rem; }
