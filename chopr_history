  /* ── RESPONSIVE ── */
  @media (max-width: 768px) {
    nav ul { display: none; }
    nav ul.open { display: flex; flex-direction: column; position: absolute; top: 60px; left: 0; right: 0; background: rgba(12,27,51,0.98); padding: 1rem 2rem 1.5rem; gap: 1rem; }
    .hamburger { display: flex; }

